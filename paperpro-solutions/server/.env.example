NODE_ENV=development
PORT=8080

MONGODB_URI=mongodb://127.0.0.1:27017/paperpro
JWT_SECRET=change_me_super_secret
JWT_EXPIRES_IN=7d

PUBLIC_APP_NAME=PaperPro Solutions
PUBLIC_WHATSAPP_NUMBER=919999999999

# Optional: enable enquiry email notifications
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=
MAIL_FROM="PaperPro Solutions <no-reply@paperpro.local>"
MAIL_TO=

# Seed admin credentials
ADMIN_SEED_EMAIL=admin@paperpro.local
ADMIN_SEED_PASSWORD=Admin@12345

# File upload
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=15

